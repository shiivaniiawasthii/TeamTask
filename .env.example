# --- Database ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/team_tasks?schema=public"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-me-with-openssl-rand-base64-32"

# --- Domain restriction for registration/invites ---
# Comma-separated list of allowed email domains (e.g., "cognifai.in,mycompany.com").
# If not set, registration is open to any domain. If set, only users with emails
# from these domains can register or be invited.
# ALLOWED_EMAIL_DOMAINS="cognifai.in"

# --- Outbound SMTP (Nodemailer) ---
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="notifications@example.com"
SMTP_PASS="your-smtp-password"

# Address used as the From / base reply-to for outbound notifications.
# Reply-to addresses for tasks are derived: <EMAIL_DOMAIN_LOCAL>+task-<id>@<EMAIL_DOMAIN>
EMAIL_FROM="Team Tasks <notifications@example.com>"
EMAIL_DOMAIN="example.com"
EMAIL_DOMAIN_LOCAL="notifications"

# --- Inbound IMAP (poller for email replies) ---
IMAP_HOST="imap.example.com"
IMAP_PORT="993"
IMAP_TLS="true"
IMAP_USER="notifications@example.com"
IMAP_PASS="your-imap-password"
IMAP_MAILBOX="INBOX"
IMAP_POLL_INTERVAL_MS="60000"

# --- Due-date reminder cron ---
DUE_REMINDER_HOURS="24"

